{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "description": "Shared settings for all Zrythm configure presets. Active presets are provided by CMakeUserPresets.json (generated by 'conan install').",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CPM_DOWNLOAD_ALL": "ON",
        "CPM_SOURCE_CACHE": "${sourceDir}/.cache/CPM",
        "FETCHCONTENT_TRY_FIND_PACKAGE_MODE": "NEVER",
        "QT_QML_GENERATE_QMLLS_INI": "ON",
        "ZRYTHM_TESTS": "ON",
        "ZRYTHM_QML_TESTS": "ON",
        "ZRYTHM_STRICT": "ON",
        "ZRYTHM_STRICT_SPHINX_OPTS": "ON",
        "ZRYTHM_WITH_LIBDW": "ON",
        "ZRYTHM_VERIFY_INTERFACE_HEADER_SETS": "ON",
        "ZRYTHM_WITH_BUNDLED_THIRD_PARTY_ATTRIBUTIONS": "ON",
        "ZRYTHM_BENCHMARKS": "ON",
        "ZRYTHM_TRACY": "OFF",
        "ZRYTHM_COMPILER_CACHE": "OFF"
      }
    }
  ]
}

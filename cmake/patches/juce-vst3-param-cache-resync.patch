VST3 host: rescan the parameter cache from the IEditController after state
restore and at instantiation, even when no IComponent state stream exists.
The VST3 SDK requires hosts to rescan parameters (getParamNormalized) after
restoring state, and controller-only state blobs are legal.

diff --git a/modules/juce_audio_processors_headless/format_types/juce_VST3PluginFormatImpl.h b/modules/juce_audio_processors_headless/format_types/juce_VST3PluginFormatImpl.h
index feeb930..4d86929 100644
--- a/modules/juce_audio_processors_headless/format_types/juce_VST3PluginFormatImpl.h
+++ b/modules/juce_audio_processors_headless/format_types/juce_VST3PluginFormatImpl.h
@@ -2844,25 +2844,22 @@ public:
                 {
                     Steinberg::int64 result;
                     componentStream->seek (0, IBStream::kIBSeekSet, &result);
-                    setComponentStateAndResetParameters (*componentStream);
+                    warnOnFailureIfImplemented (editController->setComponentState (componentStream.get()));
                 }
 
                 auto controllerStream (createMemoryStreamForState (*head, "IEditController"));
 
                 if (controllerStream != nullptr)
                     editController->setState (controllerStream.get());
+
+                // The controller is the authoritative source for parameter
+                // values. Rescan after all state streams have been applied:
+                // a state blob may contain only an IEditController stream.
+                resetParameters();
             }
         }
     }
 

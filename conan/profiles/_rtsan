[settings]
compiler.sanitizer=Realtime

[conf]
qt/*:tools.build.cross_building:cross_build=True
tools.build:cflags+=["-fsanitize=realtime", "-fno-omit-frame-pointer"]
tools.build:cxxflags+=["-fsanitize=realtime", "-fno-omit-frame-pointer"]
tools.build:exelinkflags+=["-fsanitize=realtime"]
tools.build:sharedlinkflags+=["-fsanitize=realtime"]

[buildenv]
RTSAN_OPTIONS=halt_on_error=0

[runenv]
RTSAN_OPTIONS=halt_on_error=1

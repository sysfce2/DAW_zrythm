include(_common)

[settings]
compiler=clang
compiler.version=22
compiler.libcxx=libc++
compiler.cppstd=23

[conf]
tools.build:compiler_executables={"c": "/usr/bin/clang", "cpp": "/usr/bin/clang++"}
tools.build:cflags+=["-DQT_NO_INT128", "-pipe"]
tools.build:cxxflags+=["-DQT_NO_INT128", "-pipe"]
